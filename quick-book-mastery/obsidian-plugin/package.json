{
  "name": "obsidian-quick-book-mastery",
  "version": "0.1.0",
  "description": "Quick Book Mastery - 对话式学习引导 Obsidian 插件",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
